# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Service-role key — required for USSD handler and admin operations. NEVER expose to browser.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── WalletConnect (investor face only — leave blank for consumer-only dev) ────
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=

# ── Payment rails ─────────────────────────────────────────────────────────────
# 'sim' (default) uses deterministic simulation — no real money, no keys needed.
# 'live' routes to the real provider; set credentials below first.
NEXT_PUBLIC_RAILS_MODE=sim

# Which live provider to use when RAILS_MODE=live: 'mtn' (default) or 'airtel'
NEXT_PUBLIC_RAILS_PROVIDER=mtn

# Webhook secret — set to a long random string in production.
# POST /api/rails/webhook requires x-rails-secret: <value> when set.
RAILS_WEBHOOK_SECRET=

# ── MTN MoMo (required when RAILS_PROVIDER=mtn and RAILS_MODE=live) ──────────
MTN_SUBSCRIPTION_KEY=
MTN_API_USER=
MTN_API_KEY=
# 'sandbox' for testing, 'mtnuganda' for production
MTN_TARGET_ENV=sandbox

# ── Airtel Money (required when RAILS_PROVIDER=airtel and RAILS_MODE=live) ───
AIRTEL_CLIENT_ID=
AIRTEL_CLIENT_SECRET=

# ── OTP / SMS ─────────────────────────────────────────────────────────────────
# 'sim' (default): logs code to server console + returns devCode in API response.
# 'live': sends real SMS via Africa's Talking.
#OTP_MODE=sim

# Africa's Talking credentials (required when OTP_MODE=live)
#AT_API_KEY=
#AT_USERNAME=
#AT_SENDER_ID=
